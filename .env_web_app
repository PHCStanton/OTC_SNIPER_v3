# ══════════════════════════════════════════════════════════════
# OTC SNIPER — Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── Port Assignments ──────────────────────────────────────────
# Frontend (Vite dev server)
VITE_PORT=5175

# Backend API server (main.py)
API_PORT=8001

# Streaming gateway (redis_gateway.py)
STREAM_PORT=3001

# ── Frontend → Backend URLs ───────────────────────────────────
# Vite injects VITE_ prefixed vars into the frontend at build time.
# Change these if you change the backend ports above.
VITE_API_URL=http://localhost:8001/api
VITE_WS_URL=ws://localhost:8001/ws
VITE_STREAM_URL=http://localhost:3001

# ── CORS Allowed Origins ─────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Include all ports the frontend might run on (5173–5175 covers
# the case where QuFLX-v2 Dashboard and RiskManager start first).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# ── Ops Control ───────────────────────────────────────────────
# Set to 1 to enable Chrome/Collector start/stop endpoints
QFLX_ENABLE_OPS=1